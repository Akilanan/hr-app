# Copy this file to server/.env and fill in real values.
#   PowerShell:  Copy-Item server/.env.example server/.env
#   bash:        cp server/.env.example server/.env

# ── Database ──────────────────────────────────────────────────────────────────
# Development (default): a local SQLite file, created by `npm run db:push`.
DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL): set provider = "postgresql" in prisma/schema.prisma,
# start Postgres (`docker compose up -d` from the repo root), then use e.g.:
# DATABASE_URL="postgresql://people:CHANGE_ME@localhost:5432/people_management?schema=public"
# (the password must match POSTGRES_PASSWORD in the root .env used by docker compose)
# Finally run: npm --prefix server run db:migrate

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate a strong 32+ char secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-32-plus-character-random-string"
# Short-lived access token (sent on every request).
JWT_ACCESS_EXPIRES_IN="15m"
# Long-lived refresh token (used to mint new access tokens; revoked via
# tokenVersion on logout / password change / admin reset).
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
# The web app origin, used for CORS. REQUIRED in production.
CLIENT_ORIGIN="http://localhost:5173"
NODE_ENV="development"
