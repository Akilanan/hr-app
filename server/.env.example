# Copy to .env and adjust.

# --- SQLite (default, zero setup) ---
DATABASE_URL="file:./dev.db"

# --- PostgreSQL (for production / huge data) ---
# 1. Change provider in prisma/schema.prisma from "sqlite" to "postgresql"
# 2. Set the URL below and run: npm run db:migrate
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/people_management?schema=public"

JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
NODE_ENV="development"
