{
  "name": "people-management-server",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for the People Management System.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:push": "prisma db push --skip-generate && prisma generate",
    "db:generate": "prisma generate",
    "db:sync": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:backup": "node prisma/backup.mjs",
    "seed": "tsx prisma/seed.ts",
    "create-admin": "tsx prisma/create-admin.ts",
    "ensure-admin": "tsx prisma/ensure-admin.ts",
    "seed-demo": "tsx prisma/seed-demo.ts",
    "test": "tsx test/permissions.test.ts && tsx test/integration.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.13.2",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
