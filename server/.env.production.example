# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment for the in-house Windows server.
# Copy to server/.env on the server and fill in the real values.
#   PowerShell:  Copy-Item server\.env.production.example server\.env
# Never commit the real server/.env (it is gitignored).
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (SQLite file on the server's own disk — data stays in-house) ──────
# Use an ABSOLUTE path outside the app folder so re-deploys never touch the data.
# Create the folder first:  New-Item -ItemType Directory -Force C:\PeopleHub\data
DATABASE_URL="file:C:/PeopleHub/data/app.db"

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Generate a strong secret and paste it here (the server refuses to boot without one):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="PASTE-A-64-PLUS-CHARACTER-RANDOM-HEX-STRING-HERE"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="production"

# The app's own base URL (it serves the web app + API from one origin). Used for
# the CORS allowlist; same-origin requests work regardless. Use the address staff
# type in the browser — the server's hostname or static LAN IP.
CLIENT_ORIGIN="http://peoplehub.yourcompany.local:4000"

# Set to "true" ONLY when the app is reachable over HTTPS (e.g. behind a TLS reverse
# proxy). It enables the HSTS header. Leave "false" for plain HTTP on the LAN —
# sending HSTS over HTTP would lock browsers out.
ENABLE_HTTPS="false"

# Optional: override where the built web app (client/dist) lives, if you deploy it
# somewhere other than ../../client/dist relative to the compiled server.
# CLIENT_DIST_PATH="C:/PeopleHub/app/client/dist"

# Optional: where scheduled backups are written (defaults to server/prisma/backups).
# BACKUP_DIR="C:/PeopleHub/backups"
